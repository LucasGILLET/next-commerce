generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  price          Float
  image          String
  category       String
  specifications String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
